<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Edukate</title>

    <!-- Google Web Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">

    <link rel="icon" href="~/img/favicon.ico">

    <!-- Edukate CSS -->
    <!-- Bootstrap CSS -->
    <link href="~/lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">

    <!-- Edukate CSS -->
    <link href="~/css/style.css" rel="stylesheet">
    <link href="~/scss/style.scss" rel="" />
    @Html.Kentico().PageBuilderStyles()
</head>

<body>
      
    <!-- TOPBAR -->
    <div class="container-fluid bg-dark text-white py-2 d-none d-lg-block">
        <div class="container">
            <div class="d-flex justify-content-between">
                <div>
                    <small><i class="fa fa-phone-alt mr-2"></i>+012 345 6789</small>
                    <small class="ml-3"><i class="fa fa-envelope mr-2"></i>info@edukate.com</small>
                </div>
            </div>
        </div>
    </div>

    <!-- NAVBAR -->
    <div class="container-fluid p-0">
        <nav class="navbar navbar-expand-lg bg-white navbar-light py-3 py-lg-0 px-lg-5">
            <a href="/" class="navbar-brand ml-lg-3">
                <h1 class="m-0 text-uppercase text-primary"><i class="fa fa-book-reader mr-3"></i>Edukate</h1>
            </a>

            <button type="button" class="navbar-toggler" data-toggle="collapse" data-target="#navbarCollapse">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse justify-content-between px-lg-3" id="navbarCollapse">
                <div class="navbar-nav mx-auto py-0">
                   @*  <a href="/" class="nav-item nav-link active">Home</a> *@
                    <a class="nav-link" href="/home">

                        Home
                    </a>
                    <a class="nav-link" href="/About">

                        About
                    </a>
                    <a class="nav-link" href="/Courses">

                        Courses
                    </a>
                    <div class="nav-item dropdown">
                        <a href="#" class="nav-link dropdown-toggle" data-toggle="dropdown">Pages</a>
                        <div class="dropdown-menu m-0">
                            <a href="/courses/course_1" class="dropdown-item">Course Detail</a>
                         @*    <a href="feature.html" class="dropdown-item">Our Features</a> *@
                            <a href="/instructors" class="dropdown-item">Instructors</a>
                         @*    <a href="testimonial.html" class="dropdown-item">Testimonial</a> *@
                        </div>
                    </div>
                   @*  <a href="/About" class="nav-item nav-link active">About</a>
                    <a href="/courses" class="nav-item nav-link">Courses</a>
                    <a href="/faculty" class="nav-item nav-link">Faculty</a>
                    <a href="/admission" class="nav-item nav-link">Admission</a> *@
                </div>
            </div>
            <a href="/join" class="btn btn-primary py-2 px-4 d-none d-lg-block">Join Us</a>
        </nav>
    </div>

    <!-- MAIN CONTENT -->
    <main>
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <!-- Footer Start -->
    <div class="container-fluid position-relative overlay-top bg-dark text-white-50 py-5" style="margin-top: 90px;">
        <div class="container mt-5 pt-5">
            <div class="row">
                <div class="col-md-6 mb-5">
                    <a href="/" class="navbar-brand">
                        <h1 class="mt-n2 text-uppercase text-white">
                            <i class="fa fa-book-reader mr-3"></i>Edukate
                        </h1>
                    </a>
                    <p class="m-0">
                        Accusam nonumy clita sed rebum kasd eirmod elitr.
                    </p>
                </div>

                <div class="col-md-6 mb-5">
                    <h3 class="text-white mb-4">Newsletter</h3>
                    <div class="w-100">
                        <div class="input-group">
                            <input type="text"
                                   class="form-control border-light"
                                   style="padding: 30px;"
                                   placeholder="Your Email Address">

                            <div class="input-group-append">
                                <button class="btn btn-primary px-4">
                                    Sign Up
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">

                <div class="col-md-4 mb-5">
                    <h3 class="text-white mb-4">Get In Touch</h3>

                    <p>
                        <i class="fa fa-map-marker-alt mr-2"></i>
                        123 Street, New York, USA
                    </p>

                    <p>
                        <i class="fa fa-phone-alt mr-2"></i>
                        +012 345 67890
                    </p>

                    <p>
                        <i class="fa fa-envelope mr-2"></i>
                        info@example.com
                    </p>
                </div>

                <div class="col-md-4 mb-5">
                    <h3 class="text-white mb-4">Our Courses</h3>

                    <div class="d-flex flex-column justify-content-start">
                        <a class="text-white-50 mb-2" href="#">
                            <i class="fa fa-angle-right mr-2"></i>Web Design
                        </a>

                        <a class="text-white-50 mb-2" href="#">
                            <i class="fa fa-angle-right mr-2"></i>Apps Design
                        </a>
                    </div>
                </div>

                <div class="col-md-4 mb-5">
                    <h3 class="text-white mb-4">Quick Links</h3>

                    <div class="d-flex flex-column justify-content-start">
                        <a class="text-white-50 mb-2" href="#">
                            <i class="fa fa-angle-right mr-2"></i>Privacy Policy
                        </a>

                        <a class="text-white-50" href="#">
                            <i class="fa fa-angle-right mr-2"></i>Contact
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- Footer End -->

   
<!-- jQuery (must be first) -->
    <!-- 1. jQuery FIRST -->
    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>

    <!-- 2. Waypoints (dependency of counterUp) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/waypoints/4.0.1/jquery.waypoints.min.js"></script>

    <!-- 3. CounterUp -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Counter-Up/1.0.0/jquery.counterup.min.js"></script>

    <!-- 4. Bootstrap -->
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.bundle.min.js"></script>

    <!-- 5. Others -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-easing/1.4.1/jquery.easing.min.js"></script>
    <script src="~/lib/owlcarousel/owl.carousel.min.js"></script>

    <!-- 6. Custom JS LAST -->
    <script src="~/js/main.js"></script>
    @await Html.Kentico().PageBuilderScriptsAsync()

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>