@using Edukate.Components.Widgets.AdmissionFormWidget
@model AdmissionFormWidgetViewModel

<!-- Admission Form Start -->
<div class="container-fluid py-5">
    <div class="container py-5">
        <div class="row">
            <div class="col-lg-8 mx-auto">
                <div class="section-title text-center position-relative mb-5">
                    <h6 class="d-inline-block position-relative text-secondary text-uppercase pb-2">@Model.FormTitle</h6>
                    <h1 class="display-4">Apply for Admission</h1>
                    <p class="text-muted">@Model.FormDescription</p>
                </div>

                @if (Model.IsSubmitted)
                {
                    <div class="alert alert-success text-center" role="alert">
                        <i class="fa fa-check-circle fa-3x mb-3"></i>
                        <h4>@Model.SuccessMessage</h4>
                    </div>
                }
                else
                {
                    <div class="bg-light rounded p-5">
                        <form id="admissionForm" method="post" action="/api/admission/submit">
                            @Html.AntiForgeryToken()

                            <div class="form-row">
                                <div class="col-md-12 form-group">
                                    <label for="studentName">Student Name <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" id="studentName" name="Student_Name" required placeholder="Enter your full name">
                                </div>
                            </div>

                            <div class="form-row">
                                <div class="col-md-6 form-group">
                                    <label for="email">Email Address <span class="text-danger">*</span></label>
                                    <input type="email" class="form-control" id="email" name="Email" required placeholder="your@email.com">
                                </div>
                                <div class="col-md-6 form-group">
                                    <label for="mobile">Mobile Number <span class="text-danger">*</span></label>
                                    <input type="tel" class="form-control" id="mobile" name="Mobile" required placeholder="+1234567890">
                                </div>
                            </div>

                            <div class="form-row">
                                <div class="col-md-12 form-group">
                                    <label for="courses">Course Selection <span class="text-danger">*</span></label>
                                    @* <select class="form-control" id="courses" name="Courses" required>
                                        <option value="">Select a course...</option>
                                        <option value="Web Development">Web Development</option>
                                        <option value="Graphic Design">Graphic Design</option>
                                        <option value="Digital Marketing">Digital Marketing</option>
                                        <option value="Data Science">Data Science</option>
                                        <option value="Mobile App Development">Mobile App Development</option>
                                        <option value="UI/UX Design">UI/UX Design</option>
                                        <option value="Business Management">Business Management</option>
                                        <option value="English Language">English Language</option>
                                    </select> *@
                                    <select class="form-control" id="courses" name="Courses" required>

                                        <option value="">Select a course...</option>

                                        @foreach (var course in Model.Courses)
                                        {
                                            <option value="@course.CourseTitle">
                                                @course.CourseTitle
                                            </option>
                                        }

                                    </select>
                                </div>
                            </div>

                            <div class="form-row">
                                <div class="col-md-12 form-group">
                                    <label for="message">Additional Information (Optional)</label>
                                    <textarea class="form-control" id="message" name="Message" rows="4" placeholder="Tell us more about your background and goals..."></textarea>
                                </div>
                            </div>

                            <div class="form-group text-center mb-0">
                                <button type="submit" class="btn btn-primary py-3 px-5">
                                    <i class="fa fa-paper-plane mr-2"></i>@Model.SubmitButtonText
                                </button>
                            </div>

                            <div id="formMessage" class="mt-3"></div>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
<!-- Admission Form End -->

<script>
document.getElementById('admissionForm')?.addEventListener('submit', function(e) {
    e.preventDefault();

    const formData = new FormData(this);
    const submitButton = this.querySelector('button[type="submit"]');
    const messageDiv = document.getElementById('formMessage');

    submitButton.disabled = true;
    submitButton.innerHTML = '<i class="fa fa-spinner fa-spin mr-2"></i>Submitting...';

    fetch(this.action, {
        method: 'POST',
        body: formData,
        headers: {
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            messageDiv.innerHTML = '<div class="alert alert-success"><i class="fa fa-check-circle mr-2"></i>' + data.message + '</div>';
            this.reset();
        } else {
            messageDiv.innerHTML = '<div class="alert alert-danger"><i class="fa fa-exclamation-triangle mr-2"></i>' + data.message + '</div>';
        }
    })
    .catch(error => {
        messageDiv.innerHTML = '<div class="alert alert-danger"><i class="fa fa-exclamation-triangle mr-2"></i>An error occurred. Please try again.</div>';
    })
    .finally(() => {
        submitButton.disabled = false;
        submitButton.innerHTML = '<i class="fa fa-paper-plane mr-2"></i>@Model.SubmitButtonText';
    });
});
</script>
