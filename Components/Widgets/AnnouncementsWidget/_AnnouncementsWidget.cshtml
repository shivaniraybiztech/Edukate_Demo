@using Edukate.Components.Widgets.AnnouncementsWidget

@model AnnouncementsWidgetViewModel

<!-- Announcements Start -->
<div class="container-fluid bg-image py-5">
    <div class="container py-5">
        <div class="section-title text-center position-relative mb-5">
            <h6 class="d-inline-block position-relative text-secondary text-uppercase pb-2">@Model.SectionTitle</h6>
            <h1 class="display-4">@Model.SectionHeading</h1>
        </div>

        @if (Model.Announcements != null && Model.Announcements.Any())
        {
            <div class="row">
                @foreach (var announcement in Model.Announcements)
                {
                    <div class="col-lg-6 mb-5">
                        <div class="blog-item position-relative overflow-hidden rounded shadow-sm h-100">
                            @if (!string.IsNullOrWhiteSpace(announcement.ImageUrl))
                            {
                                <img class="img-fluid" src="@announcement.ImageUrl" alt="@announcement.Title" style="width: 100%; height: 250px; object-fit: cover;">
                            }
                            else
                            {
                                <img class="img-fluid" src="/img/bg-image.jpg" alt="@announcement.Title" style="width: 100%; height: 250px; object-fit: cover;">
                            }
                            <div class="p-4 bg-light">
                                <div class="d-flex mb-3">
                                    <small class="mr-3"><i class="fa fa-calendar-alt text-primary mr-2"></i>@announcement.PublishDate.ToString("MMM dd, yyyy")</small>
                                </div>
                                <h5 class="m-0">@announcement.Title</h5>
                                @if (!string.IsNullOrWhiteSpace(announcement.ShortDescription))
                                {
                                    <p class="mt-3 mb-0">@announcement.ShortDescription</p>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (Model.ShowViewAllButton)
            {
                <div class="row">
                    <div class="col-12 text-center">
                        <a class="btn btn-primary py-3 px-5 mt-2" href="/announcements">View All Announcements</a>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-center">
                <p class="text-muted">No announcements available at the moment.</p>
            </div>
        }
    </div>
</div>
<!-- Announcements End -->
