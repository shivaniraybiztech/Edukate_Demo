@using Edukate.Components.Widgets.HeroWidget
@using Kentico.Content.Web.Mvc
@using Kentico.Web.Mvc
@inject IWebPageDataContextRetriever contextRetriever

@model HeroWidgetViewModel

@{
    var currentPath = Context.Request.Path.Value?.Trim('/') ?? "";

    var pathSegments = string.IsNullOrEmpty(currentPath)
        ? new string[0]
        : currentPath.Split('/', StringSplitOptions.RemoveEmptyEntries);

    var pageName = pathSegments.Length > 0
        ? System.Globalization.CultureInfo.CurrentCulture.TextInfo
            .ToTitleCase(pathSegments[^1].Replace("-", " "))
        : "Home";
}

<section>

    <div id="heroCarousel"
         class="carousel slide carousel-fade"
         data-ride="carousel">

        <!-- Indicators -->
        <ol class="carousel-indicators">

            @for (int i = 0; i < Model.Slides.Count; i++)
            {
                <li data-target="#heroCarousel"
                    data-slide-to="@i"
                    class="@(i == 0 ? "active" : "")">
                </li>
            }

        </ol>

        <!-- Slides -->
        <div class="carousel-inner">

            @for (int i = 0; i < Model.Slides.Count; i++)
            {
                var slide = Model.Slides[i];

                <div class="carousel-item @(i == 0 ? "active" : "")">

                    <div class="jumbotron jumbotron-fluid page-header position-relative overlay-bottom mb-0"
                         style="
                        min-height: 700px;
                        background:
                        linear-gradient(rgba(40,120,235,0.7), rgba(40,120,235,0.7)),
                        url('@slide.ImageUrl') center center / cover no-repeat;">

                        <div class="container text-center py-5 position-relative"
                             style="z-index:3;">

                           

                            <!-- Content -->
                            <div style="padding-top:100px;">

                                <!-- Small Title -->
                                <h5 class="text-white text-uppercase mb-3">
                                    @slide.Title
                                </h5>

                                <!-- Main Heading -->
                                <h1 class="display-3 text-white mb-4">
                                    @slide.MetaDescription
                                </h1>
                                <!-- Breadcrumb -->
                                <div class="d-inline-flex text-white mb-5">

                                    <p class="m-0 text-uppercase">
                                        <a class="text-white" href="/">Home</a>
                                    </p>

                                    @if (pathSegments.Length > 0)
                                    {
                                        <i class="fa fa-angle-double-right pt-1 px-3"></i>

                                        <p class="m-0 text-uppercase">
                                            @pageName
                                        </p>
                                    }

                                </div>
                                <!-- CTA Buttons -->
                                <div class="mt-4">

                                    <a href="@slide.ButtonLink"
                                       class="btn btn-primary px-5 py-3 mr-3">

                                        @slide.ButtonText

                                    </a>

                                    <a href="/admission-form"
                                       class="btn btn-outline-light px-5 py-3">

                                        Apply Now

                                    </a>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>
            }

        </div>

        <!-- Previous Button -->
        <a class="carousel-control-prev"
           href="#heroCarousel"
           role="button"
           data-slide="prev">

            <span class="carousel-control-prev-icon"></span>

        </a>

        <!-- Next Button -->
        <a class="carousel-control-next"
           href="#heroCarousel"
           role="button"
           data-slide="next">

            <span class="carousel-control-next-icon"></span>

        </a>

    </div>

</section>

