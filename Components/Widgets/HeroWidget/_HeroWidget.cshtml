@using Edukate.Components.Widgets.HeroWidget
@using Kentico.Content.Web.Mvc
@using Kentico.Web.Mvc
@inject IWebPageDataContextRetriever contextRetriever

@model HeroWidgetViewModel

@{
    var currentPath = Context.Request.Path.Value?.Trim('/') ?? "";
    var pathSegments = string.IsNullOrEmpty(currentPath) 
        ? new string[0] 
        : currentPath.Split('/', StringSplitOptions.RemoveEmptyEntries);

    // Get the last segment as the page name
    var pageName = pathSegments.Length > 0 
        ? System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(pathSegments[^1].Replace("-", " "))
        : "Home";
}

<section>

    <!-- Hero Start -->
    <div class="jumbotron jumbotron-fluid page-header position-relative overlay-bottom" 
   style="
        margin-bottom: 90px;
        min-height: 500px;
        background:
        linear-gradient(rgba(40,120,235,0.7), rgba(40,120,235,0.7)),
        url('@Model.ImageUrl') center center / cover no-repeat;">

       @*  <!-- Background Image -->
        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl"
                 class="position-absolute w-100 h-100"
                 style="object-fit: cover; top:0; left:0; z-index:1;"
                 alt="Hero Image" />
        }

        <div class="position-absolute w-100 h-100"
             style="top:0; left:0; background: rgba(0, 68, 204, 0.6); z-index:2;">
        </div> *@

        <!-- Content -->
        <div class="container text-center py-5 position-relative" style="z-index:3;">

            <!-- Breadcrumb -->
            <div class="d-inline-flex text-white mb-5">
                <p class="m-0 text-uppercase">
                    <a class="text-white" href="/">Home</a>
                </p>

                @if (pathSegments.Length > 0)
                {
                    <i class="fa fa-angle-double-right pt-1 px-3"></i>
                    <p class="m-0 text-uppercase">@pageName</p>
                }
            </div>

            <!-- Small Title -->
            <h5 class="text-white text-uppercase mb-3">
                @Model.Title
            </h5>

            <!-- Main Heading -->
            <h1 class="display-3 text-white mb-4">
                @Model.MetaDescription
            </h1>

            <!-- Search Box -->
            <div class="mx-auto mb-5"
                 style="width: 100%; max-width: 600px;">

                <div class="input-group">

                    <div class="input-group-prepend">

                        <button class="btn btn-outline-light bg-white text-body px-4 dropdown-toggle"
                                type="button"
                                data-toggle="dropdown"
                                aria-haspopup="true"
                                aria-expanded="false">
                            Courses
                        </button>

                        <div class="dropdown-menu">
                            <a class="dropdown-item" href="/courses/course_1">Complete Web Development Bootcamp</a>
                            <a class="dropdown-item" href="/courses/course_2">UI UX Design Fundamentals</a>
                            <a class="dropdown-item" href="/courses/course_3">Digital Marketing Mastery</a>
                        </div>

                    </div>

                    <input type="text"
                           class="form-control border-light"
                           style="padding: 30px 25px;"
                           placeholder="Keyword">

                    <div class="input-group-append">
                        <button class="btn btn-secondary px-4 px-lg-5">
                            Search
                        </button>
                    </div>

                </div>

            </div>

        </div>

      @*   <!-- Wave Shape Bottom -->
        <div class="position-absolute w-100"
             style="bottom: 0; z-index:3;">

            <svg viewBox="0 0 500 150"
                 preserveAspectRatio="none"
                 style="height: 60px; width: 100%;">

                <path d="M0.00,49.98 C150.00,150.00 349.20,-50.00 500.00,49.98
                    L500.00,150.00 L0.00,150.00 Z"
                      style="stroke: none; fill: #ffffff;">
                </path>

            </svg>

        </div> *@

    </div>
    <!-- Hero End -->

</section>