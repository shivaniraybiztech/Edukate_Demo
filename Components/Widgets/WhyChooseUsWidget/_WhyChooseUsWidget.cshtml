@using Edukate.Components.Widgets.WhyChooseUsWidget

@model WhyChooseUsWidgetViewModel

<!-- Feature Start -->
<div class="container-fluid bg-image py-5">
    <div class="container py-5">
        <div class="row">
            <div class="col-lg-7 mb-5 mb-lg-0">
                <div class="section-title position-relative mb-4">
                    <h6 class="d-inline-block position-relative text-secondary text-uppercase pb-2">
                        @Model.SectionSubtitle
                    </h6>
                    <h1 class="display-4">
                        @Model.SectionTitle
                    </h1>
                </div>
                <p class="mb-4 pb-2">
                    @Model.IntroText
                </p>

                <!-- Feature 1 -->
                <div class="d-flex mb-3">
                    <div class="btn-icon bg-@Model.Feature1BgColor mr-4">
                        <i class="@Model.Feature1Icon fa-2x text-white"></i>
                    </div>
                    <div class="mt-n1">
                        <h4>@Model.Feature1Title</h4>
                        <p>@Model.Feature1Description</p>
                    </div>
                </div>

                <!-- Feature 2 -->
                <div class="d-flex mb-3">
                    <div class="btn-icon bg-@Model.Feature2BgColor mr-4">
                        <i class="@Model.Feature2Icon fa-2x text-white"></i>
                    </div>
                    <div class="mt-n1">
                        <h4>@Model.Feature2Title</h4>
                        <p>@Model.Feature2Description</p>
                    </div>
                </div>

                <!-- Feature 3 -->
                <div class="d-flex">
                    <div class="btn-icon bg-@Model.Feature3BgColor mr-4">
                        <i class="@Model.Feature3Icon fa-2x text-white"></i>
                    </div>
                    <div class="mt-n1">
                        <h4>@Model.Feature3Title</h4>
                        <p class="m-0">@Model.Feature3Description</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-5" style="min-height: 500px;">
                <div class="position-relative h-100">
                    @if (!string.IsNullOrWhiteSpace(Model.FeatureImageUrl))
                    {
                        <img class="position-absolute w-100 h-100" 
                             src="@Model.FeatureImageUrl" 
                             style="object-fit: cover;"
                             alt="@Model.SectionTitle">
                    }
                    else
                    {
                        <img class="position-absolute w-100 h-100" 
                             src="~/img/feature.jpg" 
                             style="object-fit: cover;"
                             alt="@Model.SectionTitle">
                    }
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Feature End -->
