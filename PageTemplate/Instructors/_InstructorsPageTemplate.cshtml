@using Edukate
@using CMS.ContentEngine
@using Kentico.Content.Web.Mvc
@using Kentico.Content.Web.Mvc.PageBuilder
@using Kentico.PageBuilder.Web.Mvc
@using Kentico.Web.Mvc
@addTagHelper *, Kentico.Content.Web.Mvc
@inject IContentRetriever contentRetriever
@inject IContentQueryExecutor contentQueryExecutor

@{
    Layout = "_Layout";

    // Retrieve the current instructor page
    var pageParameters = new RetrieveCurrentPageParameters
    {
        LinkedItemsMaxLevel = 1
    };

    var currentPage = await contentRetriever.RetrieveCurrentPage<InstructorPage>(pageParameters);

    ViewData["Title"] = currentPage?.Title ?? "Our Instructors";

    // Query all instructors
    var query = new ContentItemQueryBuilder()
        .ForContentType(
            InstructorItem.CONTENT_TYPE_NAME,
            config =>
            {
                config.WithLinkedItems(2);
            });

    var instructorItems = await contentQueryExecutor.GetMappedResult<InstructorItem>(query);

    // Map to view models
    var instructors = instructorItems.Select(item =>
    {
        string imageUrl = string.Empty;
        var imageItem = item.Photo?.FirstOrDefault();
        if (imageItem?.ImageFile != null)
        {
            imageUrl = imageItem.ImageFile.Url;
        }

        return new
        {
            Name = item.Name,
            Designation = item.Designation,
            ImageUrl = imageUrl,
            TwitterURL = item.TwitterURL,
            FacebookURL = item.FacebookURL,
            LinkedInURL = item.LinkedInURL,
            InstagramURL = item.InstagramURL,
            YoutubeURL = item.YoutubeURL,
            Url = item.SlugUrl
        };
    }).ToList();
}
<section>
    <editable-area area-identifier="hero-area"></editable-area>
</section>
<!-- Team Start -->
<div class="container-fluid py-5">
    <div class="container py-5">
        <div class="section-title text-center position-relative mb-5">
            <h6 class="d-inline-block position-relative text-secondary text-uppercase pb-2">Our Instructors</h6>
            <h1 class="display-4">@(currentPage?.Title ?? "Meet Our Expert Instructors")</h1>
        </div>

        @if (instructors != null && instructors.Any())
        {
            <div class="owl-carousel team-carousel position-relative" style="padding: 0 30px;">

                @foreach (var instructor in instructors)
                {
                    <div class="team-item">
                        <a class="courses-list-item position-relative d-block overflow-hidden mb-2" href="@instructor.Url">

                        @if (!string.IsNullOrWhiteSpace(instructor.ImageUrl))
                        {
                            <img class="img-fluid w-100" src="@instructor.ImageUrl" alt="@instructor.Name">
                        }
                        else
                        {
                            <img class="img-fluid w-100" src="/img/team-1.jpg" alt="@instructor.Name">
                        }
                        <div class="bg-light text-center p-4">
                            <h5 class="mb-3">@instructor.Name</h5>
                            <p class="mb-2">@instructor.Designation</p>
                            <div class="d-flex justify-content-center">
                                @if (!string.IsNullOrWhiteSpace(instructor.TwitterURL))
                                {
                                    <a class="mx-1 p-1" href="@instructor.TwitterURL" target="_blank"><i class="fab fa-twitter"></i></a>
                                }
                                @if (!string.IsNullOrWhiteSpace(instructor.FacebookURL))
                                {
                                    <a class="mx-1 p-1" href="@instructor.FacebookURL" target="_blank"><i class="fab fa-facebook-f"></i></a>
                                }
                                @if (!string.IsNullOrWhiteSpace(instructor.LinkedInURL))
                                {
                                    <a class="mx-1 p-1" href="@instructor.LinkedInURL" target="_blank"><i class="fab fa-linkedin-in"></i></a>
                                }
                                @if (!string.IsNullOrWhiteSpace(instructor.InstagramURL))
                                {
                                    <a class="mx-1 p-1" href="@instructor.InstagramURL" target="_blank"><i class="fab fa-instagram"></i></a>
                                }
                                @if (!string.IsNullOrWhiteSpace(instructor.YoutubeURL))
                                {
                                    <a class="mx-1 p-1" href="@instructor.YoutubeURL" target="_blank"><i class="fab fa-youtube"></i></a>
                                }
                            </div>
                        </div>
                        </a>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center">
                <p class="text-muted">No instructors available at the moment.</p>
            </div>
        }
    </div>
</div>
<!-- Team End -->
