@using Edukate.PageTemplate.Courses

@model CoursesPageTemplateViewModel

<!-- Courses Start -->
<div class="container-fluid py-5">
    <div class="container py-5">
        <div class="row mx-0 justify-content-center">
            <div class="col-lg-8">
                <div class="section-title text-center position-relative mb-5">
                    <h6 class="d-inline-block position-relative text-secondary text-uppercase pb-2">@Model.SectionTitle</h6>
                    <h1 class="display-4">@Model.SectionHeading</h1>
                </div>
            </div>
        </div>

        @if (Model.Courses != null && Model.Courses.Any())
        {
            <div class="row">
                @foreach (var course in Model.Courses)
                {
                    <div class="col-lg-4 col-md-6 pb-4">
                        <a class="courses-list-item position-relative d-block overflow-hidden mb-2" href="@course.CourseUrl">
                            @if (!string.IsNullOrWhiteSpace(course.ImageUrl))
                            {
                                <img class="img-fluid" src="@course.ImageUrl" alt="@course.CourseName">
                            }
                            else
                            {
                                <img class="img-fluid" src="~/img/courses-1.jpg" alt="@course.CourseName">
                            }
                            <div class="courses-text">
                                <h4 class="text-center text-white px-3">@course.Title</h4>
                                <div class="border-top w-100 mt-3">
                                    <div class="d-flex justify-content-between p-4">
                                        <span class="text-white"><i class="fa fa-user mr-2"></i>@course.Instructor</span>
                                        <span class="text-white"><i class="fa fa-star mr-2"></i>@course.Rating
                                            <small>(@course.ReviewCount)</small></span>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }

                <div class="col-12">
                    <nav aria-label="Page navigation">
                        <ul class="pagination pagination-lg justify-content-center mb-0">

                            <!-- Previous -->
                            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link rounded-0"
                                   href="?page=@(Model.CurrentPage - 1)">
                                    &laquo;
                                </a>
                            </li>

                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                    <a class="page-link" href="?page=@i">@i</a>
                                </li>
                            }

                            <!-- Next -->
                            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                <a class="page-link rounded-0"
                                   href="?page=@(Model.CurrentPage + 1)">
                                    &raquo;
                                </a>
                            </li>

                        </ul>
                    </nav>
                </div>
            </div>
        }
        else
        {
            <div class="row">
                <div class="col-12">
                    <p class="text-center">No courses available at this time.</p>
                </div>
            </div>
        }
    </div>
</div>
<!-- Courses End -->
